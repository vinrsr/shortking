{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "LOCALAPPDATA",
    "APPDATA",
    "TEMP",
    "TMP",
    "USERPROFILE"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "env": [
        "INTERNAL_API_URL"
      ],
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "bin/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ]
    }
  }
}